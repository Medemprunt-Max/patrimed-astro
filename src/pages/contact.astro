---
import Layout from '../layouts/Layout.astro';
import HeroCompact from '../components/HeroCompact.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';

const contactInfo = [
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />',
    label: 'Telephone',
    value: '01 77 62 44 81',
    href: 'tel:0177624481',
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />',
    label: 'Email',
    value: 'contact@patrimed.fr',
    href: 'mailto:contact@patrimed.fr',
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />',
    label: 'Adresse',
    value: '131 boulevard Pereire, 75017 Paris',
    href: null,
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />',
    label: 'Disponibilite',
    value: '6j/7 jusqu\'a 23h',
    href: null,
  },
];

const socials = [
  { label: 'Facebook', href: 'https://facebook.com/profile.php?id=100095108701526', icon: 'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z' },
  { label: 'Instagram', href: 'https://instagram.com/patrimed.fr', icon: 'M16 4H8a4 4 0 00-4 4v8a4 4 0 004 4h8a4 4 0 004-4V8a4 4 0 00-4-4zm-4 11a3 3 0 110-6 3 3 0 010 6zm3.5-6.5a.75.75 0 110-1.5.75.75 0 010 1.5z' },
  { label: 'LinkedIn', href: 'https://linkedin.com/company/patrimed-fr/', icon: 'M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 6a2 2 0 100-4 2 2 0 000 4z' },
];
---

<Layout title="Contact — Patrimed" description="Contactez Patrimed. Disponible 6j/7 jusqu'a 23h en visio. 01 77 62 44 81, contact@patrimed.fr.">
  <HeroCompact
    title="Nous"
    highlight="contacter"
    subtitle="Notre equipe est disponible 6j/7, jusqu'a 23h, pour repondre a toutes vos questions et vous accompagner dans votre strategie patrimoniale."
  />

  <!-- Contact info + Form -->
  <Section>
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
      <!-- Left: Info -->
      <div class="lg:col-span-2">
        <h2 class="font-display text-2xl font-bold text-dark mb-8">
          Echangez avec nos <span class="gradient-text">conseillers</span>
        </h2>

        <div class="space-y-6">
          {contactInfo.map((info) => (
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-primary-50 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-pat-plum" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <Fragment set:html={info.icon} />
                </svg>
              </div>
              <div>
                <p class="text-gray-400 text-sm">{info.label}</p>
                {info.href ? (
                  <a href={info.href} class="text-dark font-semibold text-lg hover:text-pat-plum transition-colors">
                    {info.value}
                  </a>
                ) : (
                  <p class="text-dark font-semibold text-lg">{info.value}</p>
                )}
              </div>
            </div>
          ))}
        </div>

        <!-- Socials -->
        <div class="mt-10">
          <p class="text-gray-400 text-sm mb-4">Nos reseaux :</p>
          <div class="flex items-center gap-3">
            {socials.map((social) => (
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.label}
                class="w-11 h-11 flex items-center justify-center rounded-xl bg-gray-50 hover:bg-pat-plum hover:text-white text-gray-400 transition-all duration-200 border border-gray-100 hover:border-pat-plum"
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={social.icon} />
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: Form + SimplyBook -->
      <div class="lg:col-span-3 space-y-8">
        <!-- Formulaire Tally -->
        <div class="bg-white rounded-2xl border border-gray-100 p-6 md:p-8 shadow-sm">
          <h3 class="font-display text-xl font-bold text-dark mb-6">Envoyez-nous un message</h3>
          <div class="rounded-xl overflow-hidden">
            <iframe
              data-tally-src="https://tally.so/embed/w7KBNL?alignLeft=1&hideTitle=1&transparentBackground=1"
              loading="lazy"
              width="100%"
              height="450"
              frameborder="0"
              marginheight="0"
              marginwidth="0"
              title="Formulaire de contact"
            ></iframe>
          </div>
        </div>

        <!-- SimplyBook.me Widget -->
        <div class="bg-white rounded-2xl border border-gray-100 p-6 md:p-8 shadow-sm">
          <h3 class="font-display text-xl font-bold text-dark mb-2">Prendre rendez-vous</h3>
          <p class="text-gray-500 text-sm mb-6">Reservez un creneau de visioconference gratuit avec l'un de nos conseillers.</p>
          <div class="rounded-xl overflow-hidden border border-gray-100">
            <iframe
              src="https://rdvlgmed.simplybook.it/v2/#book"
              width="100%"
              height="600"
              frameborder="0"
              loading="lazy"
              title="Reserver un rendez-vous - SimplyBook.me"
              class="w-full"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- CTA -->
  <Section bg="dark">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-6">
        Un projet <span class="gradient-text">patrimonial</span> ?
      </h2>
      <p class="text-gray-300 text-lg mb-8">
        N'hesitez pas a nous contacter, notre equipe est la pour vous accompagner a chaque etape.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:0177624481" class="btn-primary text-lg">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          01 77 62 44 81
        </a>
        <a href="mailto:contact@patrimed.fr" class="btn-secondary border-white/30 text-white hover:bg-white hover:text-dark text-lg">
          contact@patrimed.fr
        </a>
      </div>
    </div>
  </Section>
</Layout>

<script>
  // Load Tally embed script
  const d = document;
  const w = "https://tally.so/widgets/embed.js";
  const v = function() {
    if (typeof (window as any).Tally !== 'undefined') {
      (window as any).Tally.loadEmbeds();
    } else {
      d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach((e: any) => {
        e.src = e.dataset.tallySrc;
      });
    }
  };
  if (typeof (window as any).Tally !== 'undefined') {
    v();
  } else if (!d.querySelector(`script[src="${w}"]`)) {
    const s = d.createElement("script");
    s.src = w;
    s.onload = v;
    s.onerror = v;
    d.body.appendChild(s);
  }
</script>
