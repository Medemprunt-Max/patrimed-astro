---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';

const engagements = [
  {
    num: '01',
    title: 'Experts des statuts',
    description: 'Nous comprenons vos différents statuts : Interne, CCA, PH, docteur junior, assistant, libéraux en SELARL, SELAS, SCM…',
  },
  {
    num: '02',
    title: 'Humains',
    description: 'Fini les chatbots ! Bien qu\'à l\'ère du digital, profitez d\'un conseiller dédié pour échanger sur vos projets de vie, peu importe la période !',
  },
  {
    num: '03',
    title: 'Disponibles',
    description: 'Vos horaires ? Nos horaires ! Nous sommes disponibles en visioconférence, 6j/7 et jusqu\'à 23h.',
  },
];

const services = [
  { title: 'Financement de résidence principale', description: 'Vous souhaitez obtenir un crédit immobilier ? Medemprunt vous négocie votre prêt aux meilleures conditions !' },
  { title: 'Financement d\'installation', description: 'Vous souhaitez installer votre cabinet en tant que libéral ? Nous vous accompagnons pour obtenir un prêt aux meilleures conditions pour votre installation !' },
  { title: 'Financement de vos travaux', description: 'Nous vous aidons à financer vos travaux énergétiques ! Découvrez dès maintenant les avantages qui vous attendent.' },
  { title: 'Gestion de patrimoine', description: 'Avec Patrimed protégez votre famille, vos revenus et votre santé !' },
];
---

<Layout
  title="Courtier crédit immobilier pour médecins, pharmaciens et dentistes"
  description="Courtier spécialisé professions médicales. Obtenez les meilleures conditions de prêt immobilier grâce à nos experts qui comprennent votre statut. Conseil gratuit."
>
  <!-- Hero -->
  <section class="relative gradient-bg overflow-hidden flex items-center">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-32 -right-32 w-[600px] h-[600px] bg-med-blue/10 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-accent/10 rounded-full blur-3xl"></div>
    </div>

    <div class="container-custom relative pt-20 pb-20 lg:pb-0 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">
          L'emprunt pour les médecins,
          <span class="gradient-text italic"> pharmaciens et dentistes</span>
        </h1>
        <p class="mt-6 text-gray-300 text-lg md:text-xl leading-relaxed max-w-lg">
          Notre mission : accompagner les professions médicales pour trouver la meilleure offre de prêt
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <Button href="/simulation" variant="primary" size="lg">
            Simuler un prêt
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </Button>
        </div>

        <ul class="mt-8 space-y-2">
          <li class="flex items-center gap-2 text-gray-300">
            <svg class="w-5 h-5 text-med-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            dans les meilleures conditions !
          </li>
          <li class="flex items-center gap-2 text-gray-300">
            <svg class="w-5 h-5 text-med-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            en gagnant du temps !
          </li>
          <li class="flex items-center gap-2 text-gray-300">
            <svg class="w-5 h-5 text-med-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            en économisant de l'argent !
          </li>
        </ul>
      </div>

      <div class="hidden lg:flex justify-center">
        <img
          src="https://medemprunt.fr/wp-content/uploads/sites/10/woman-doctor-wearing-lab-coat-with-stethoscope-isolated-609x1024.png"
          alt="Médecin avec stéthoscope"
          class="w-96 h-auto rounded-3xl object-cover"
        />
      </div>
    </div>
  </section>

  <!-- Engagements -->
  <Section bg="gray">
    <div class="text-center mb-16">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-dark">
        Nos <span class="gradient-text">engagements</span>
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {engagements.map((e, i) => (
        <div class="reveal bg-white rounded-2xl border border-gray-100 p-8 card-hover" style={`transition-delay: ${i * 100}ms`}>
          <span class="text-4xl font-display font-extrabold gradient-text">{e.num}.</span>
          <h3 class="font-display text-xl font-bold text-dark mt-4 mb-3">{e.title}</h3>
          <p class="text-gray-500 leading-relaxed">{e.description}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Services -->
  <Section>
    <div class="text-center mb-16">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-dark">
        Nos différents <span class="gradient-text">services</span>
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {services.map((s, i) => (
        <div class="reveal bg-white rounded-2xl border border-gray-100 p-8 card-hover" style={`transition-delay: ${i * 80}ms`}>
          <h3 class="font-display text-lg font-bold text-dark mb-3">{s.title}</h3>
          <p class="text-gray-500 leading-relaxed">{s.description}</p>
        </div>
      ))}
    </div>
    <div class="text-center mt-12">
      <Button href="/rdv" variant="primary" size="lg">
        Prendre RDV
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </Button>
    </div>
  </Section>
</Layout>
