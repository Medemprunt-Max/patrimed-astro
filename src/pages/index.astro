---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import StatCounter from '../components/StatCounter.astro';
import PartnerLogo from '../components/PartnerLogo.astro';

const valueProps = [
  {
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    title: 'Zéro conflit d\'intérêts',
    description: 'Même bonus pour le conseiller quel que soit le produit. Votre intérêt passe en premier !',
  },
  {
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Disponibles quand vous l\'êtes',
    description: 'RDV gratuits en visio jusqu\'à 23h, du lundi au samedi. Votre conseiller reste joignable par mail, téléphone ou SMS.',
  },
  {
    icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
    title: 'Frais bas, performances hautes',
    description: 'Sans bureaux ni commerciaux terrain, et grâce à des outils partagés avec Medemprunt, nous réduisons nos coûts pour vous proposer des produits de qualité à frais réduits.',
  },
];

const services = [
  {
    num: '01',
    title: 'Patrimoine',
    desc: 'Assurance Vie, PER, SCPI, Compte-titres, PEA, ingénierie financière.',
    icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    size: 'lg',
  },
  {
    num: '02',
    title: 'Fiscalité',
    desc: 'Girardin, Malraux, stratégies d\'optimisation fiscale sur mesure.',
    icon: 'M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z',
    size: 'md',
  },
  {
    num: '03',
    title: 'Protection',
    desc: 'Prévoyance, capital décès, rente éducation, frais obsèques.',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    size: 'sm',
  },
  {
    num: '04',
    title: 'Retraite',
    desc: 'Optimisation PER, ETF et réduction frais de gestion, projection chiffrée.',
    icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
    size: 'wide',
    accent: true,
  },
  {
    num: '05',
    title: 'Immobilier & Crédit',
    desc: 'SCPI, stratégies d\'investissement immobilier, lien avec Medemprunt.',
    icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
    size: 'wide',
  },
];

const partners = [
  'Generali', 'Suravenir', 'Spirica', 'Swiss Life', 'Cardif',
  'Abeille', 'La France Mutualiste', 'Corum', 'Primonial',
  'Inter Invest', 'Linxea', 'Nortia',
];

const stats = [
  { value: '500', suffix: '+', label: 'Clients accompagnés' },
  { value: '25', suffix: '+', label: 'Partenaires financiers' },
  { value: '98', suffix: '%', label: 'Taux de satisfaction' },
  { value: '6', suffix: 'j/7', label: 'Disponibilité' },
];

const days = ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam'];
---

<Layout
  title="Patrimed — Gestion de patrimoine pour professionnels de santé"
  description="Conseil patrimonial indépendant dédié aux médecins et professions médicales. Assurance vie, PER, SCPI, fiscalité. RDV gratuit."
  headerVariant="light"
>
  <!-- Hero Light -->
  <section class="hero-light relative overflow-hidden -mt-16 md:-mt-20 pt-32 md:pt-44 pb-20 lg:pb-32">
    <!-- Decorative — subtle, diffused halos -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-pat-plum/[0.04] rounded-full blur-[120px]"></div>
      <div class="absolute -bottom-60 -left-40 w-[500px] h-[500px] bg-accent/[0.03] rounded-full blur-[100px]"></div>
      <div class="absolute -top-32 -right-32 w-[350px] h-[350px] bg-pat-plum/[0.03] rounded-full blur-[80px]"></div>
    </div>

    <div class="container-custom relative text-center max-w-4xl mx-auto">
      <!-- Overline tag -->
      <div class="reveal inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary-50 border border-primary-100 mb-8">
        <span class="flex h-2 w-2 rounded-full bg-pat-plum/60"></span>
        <span class="text-sm text-pat-plum font-semibold tracking-wide">Conseil patrimonial indépendant</span>
      </div>

      <!-- H1 — large, airy, strong hierarchy -->
      <h1 class="reveal font-display text-4xl md:text-6xl lg:text-7xl font-extrabold text-dark leading-[1.08] tracking-tight">
        Gestion de patrimoine
        <br />
        <span class="gradient-text">pour les professionnels de santé</span>
      </h1>

      <!-- Baseline — serif for contrast -->
      <p class="reveal mt-6 md:mt-8 font-serif text-gray-500 text-lg md:text-xl lg:text-2xl leading-relaxed max-w-2xl mx-auto italic">
        Pour la santé de votre patrimoine
      </p>

      <!-- CTAs — dominant primary, subtle secondary -->
      <div class="reveal mt-10 md:mt-14 flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/rdv" variant="primary" size="lg" class="text-base md:text-lg px-8 py-4 md:px-10 md:py-5 rounded-2xl shadow-lg shadow-pat-plum/20">
          Prendre rendez-vous
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </Button>
        <Button href="/gestion-patrimoine" variant="secondary" size="lg" class="rounded-2xl">
          Découvrir nos services
        </Button>
      </div>

      <!-- Trust indicators — repositioned below CTAs with separator -->
      <div class="reveal mt-14 md:mt-20 pt-8 border-t border-gray-200/60">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-8 max-w-3xl mx-auto">
          <div class="flex flex-col items-center gap-2.5">
            <div class="flex items-center justify-center w-11 h-11 rounded-xl bg-primary-50">
              <svg class="w-5 h-5 text-pat-plum" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <span class="text-sm font-semibold text-dark">Votre intérêt d'abord</span>
            <span class="text-xs text-gray-400">Zéro conflit d'intérêts</span>
          </div>
          <div class="flex flex-col items-center gap-2.5">
            <div class="flex items-center justify-center w-11 h-11 rounded-xl bg-primary-50">
              <svg class="w-5 h-5 text-pat-plum" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
            </div>
            <span class="text-sm font-semibold text-dark">RDV gratuits en visio</span>
            <span class="text-xs text-gray-400">Premier échange offert</span>
          </div>
          <div class="flex flex-col items-center gap-2.5">
            <div class="flex items-center justify-center w-11 h-11 rounded-xl bg-primary-50">
              <svg class="w-5 h-5 text-pat-plum" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <span class="text-sm font-semibold text-dark">Visio jusqu'à 23h, 6j/7</span>
            <span class="text-xs text-gray-400">Adaptés à vos horaires</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats banner -->
  <section class="stats-banner py-16">
    <div class="container-custom">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map((stat) => (
          <StatCounter value={stat.value} suffix={stat.suffix} label={stat.label} />
        ))}
      </div>
    </div>
  </section>

  <!-- Value propositions -->
  <Section bg="white">
    <div class="text-center mb-16">
      <h2 class="reveal font-display text-3xl md:text-4xl font-bold text-dark">
        Pourquoi choisir <span class="gradient-text">Patrimed</span> ?
      </h2>
      <p class="reveal mt-4 text-gray-500 text-lg max-w-2xl mx-auto">
        Un accompagnement sur-mesure pour les professionnels de santé qui veulent faire fructifier leur patrimoine.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {valueProps.map((vp, i) => (
        <div class="reveal bg-white rounded-2xl border border-gray-100 p-8 card-hover" style={`transition-delay: ${i * 100}ms`}>
          <div class="w-14 h-14 rounded-xl bg-primary-50 flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-pat-plum" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={vp.icon} />
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-dark mb-3">{vp.title}</h3>
          <p class="text-gray-500 leading-relaxed">{vp.description}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Bento grid services -->
  <Section bg="gray">
    <div class="text-center mb-16">
      <h2 class="reveal font-display text-3xl md:text-4xl font-bold text-dark">
        Nos <span class="gradient-text">solutions</span> patrimoniales
      </h2>
      <p class="reveal mt-4 text-gray-500 text-lg max-w-2xl mx-auto">
        5 domaines d'expertise pour une stratégie patrimoniale complète et personnalisée.
      </p>
    </div>

    <div class="grid grid-cols-12 gap-4 md:gap-6">
      {services.map((s, i) => {
        const colSpan = s.size === 'lg' ? 'col-span-12 md:col-span-7'
          : s.size === 'md' ? 'col-span-12 md:col-span-5'
          : s.size === 'sm' ? 'col-span-12 md:col-span-5'
          : 'col-span-12';
        const isAccent = s.accent;

        return (
          <a
            href="/gestion-patrimoine"
            class:list={[
              'reveal group block rounded-2xl p-8 transition-all duration-300 hover:shadow-xl hover:-translate-y-1',
              colSpan,
              isAccent ? 'bento-item-accent text-white' : 'bg-white border border-gray-100',
            ]}
            style={`transition-delay: ${i * 80}ms`}
          >
            <div class="flex items-start justify-between mb-6">
              <span class:list={[
                'text-4xl font-display font-extrabold',
                isAccent ? 'text-white/30' : 'gradient-text',
              ]}>{s.num}</span>
              <div class:list={[
                'w-12 h-12 rounded-xl flex items-center justify-center',
                isAccent ? 'bg-white/10' : 'bg-primary-50',
              ]}>
                <svg class:list={['w-6 h-6', isAccent ? 'text-white' : 'text-pat-plum']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={s.icon} />
                </svg>
              </div>
            </div>
            <h3 class:list={[
              'font-display text-xl font-bold mb-2',
              isAccent ? 'text-white' : 'text-dark',
            ]}>{s.title}</h3>
            <p class:list={[
              'leading-relaxed',
              isAccent ? 'text-white/80' : 'text-gray-500',
            ]}>{s.desc}</p>
            <span class:list={[
              'inline-flex items-center gap-1 text-sm font-semibold mt-4 group-hover:gap-2 transition-all',
              isAccent ? 'text-white' : 'text-pat-plum',
            ]}>
              En savoir plus
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </a>
        );
      })}
    </div>
  </Section>

  <!-- Availability -->
  <Section bg="white">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="reveal">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-dark mb-4">
          Vos horaires ? <span class="gradient-text">Nos horaires !</span>
        </h2>
        <p class="text-gray-500 text-lg leading-relaxed mb-6">
          Nous savons que votre emploi du temps est chargé. C'est pourquoi nous sommes disponibles en visioconférence <strong class="text-dark">6 jours sur 7</strong>, de 9h à 23h.
        </p>
        <ul class="space-y-3 mb-8">
          <li class="flex items-center gap-3 text-gray-600">
            <svg class="w-5 h-5 text-pat-plum flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            Visioconférence depuis chez vous
          </li>
          <li class="flex items-center gap-3 text-gray-600">
            <svg class="w-5 h-5 text-pat-plum flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            Créneaux en soirée et le samedi
          </li>
          <li class="flex items-center gap-3 text-gray-600">
            <svg class="w-5 h-5 text-pat-plum flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            Premier rendez-vous gratuit et sans engagement
          </li>
        </ul>
        <Button href="/rdv" variant="primary" size="lg">
          Réserver un créneau
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </Button>
      </div>

      <div class="reveal">
        <div class="bg-gray-50 rounded-2xl p-6 md:p-8 border border-gray-100">
          <div class="grid grid-cols-6 gap-3">
            {days.map((day) => (
              <div class="text-center">
                <div class="bg-white rounded-xl p-4 border border-gray-100 hover:border-pat-plum/20 hover:shadow-soft transition-all duration-300">
                  <span class="block text-xs text-gray-400 mb-1">{day}</span>
                  <span class="block text-lg font-display font-bold text-dark">9h</span>
                  <div class="w-full h-px bg-gray-200 my-2"></div>
                  <span class="block text-lg font-display font-bold text-pat-plum">23h</span>
                </div>
              </div>
            ))}
          </div>
          <p class="text-center text-gray-400 text-sm mt-4">Horaires de disponibilité en visioconférence</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- CTA Final -->
  <section class="gradient-bg py-20 md:py-28">
    <div class="container-custom text-center max-w-3xl mx-auto">
      <h2 class="reveal font-display text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6">
        Prêt à optimiser votre <span class="gradient-text">patrimoine</span> ?
      </h2>
      <p class="reveal text-gray-300 text-lg md:text-xl mb-10 leading-relaxed">
        Prenez rendez-vous pour un premier échange gratuit et sans engagement avec un conseiller spécialisé.
      </p>
      <div class="reveal flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/rdv" variant="white" size="lg">
          Prendre rendez-vous
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </Button>
        <Button href="/contact" variant="secondary" size="lg" class="border-white/30 text-white hover:bg-white/10 hover:text-white">
          Nous contacter
        </Button>
      </div>
    </div>
  </section>
</Layout>
