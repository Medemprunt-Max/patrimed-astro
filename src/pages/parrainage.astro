---
import Layout from '../layouts/Layout.astro';
import HeroCompact from '../components/HeroCompact.astro';
import Section from '../components/Section.astro';
import SectionTitle from '../components/SectionTitle.astro';
import Button from '../components/Button.astro';

const steps = [
  {
    num: '01',
    title: 'Invitez',
    description: 'Parlez de Patrimed à un confrère et remplissez le formulaire ci-dessous avec ses coordonnées.',
  },
  {
    num: '02',
    title: 'Nous accompagnons',
    description: 'Votre confrère bénéficie d\'un RDV visio gratuit et de notre expertise en gestion de patrimoine.',
  },
  {
    num: '03',
    title: 'Vous gagnez',
    description: 'Dès l\'ouverture d\'une Assurance Vie ou d\'un PER, vous recevez 215 € en parts de SCPI ou 100 € en cash.',
  },
];
---

<Layout
  title="Programme de parrainage — Patrimed"
  description="Parrainez un confrère et recevez 215 € en SCPI ou 100 € en cash."
>
  <HeroCompact
    title="Parrainage : Gagnez 215 €"
    highlight="de SCPI !"
    subtitle="Nous vous offrons 215 € en parts de SCPI pour chaque confrère parrainé*"
  />

  <!-- Comment ça marche -->
  <Section>
    <SectionTitle
      title="Comment ça"
      highlight="marche ?"
      subtitle="Un processus simple en trois étapes pour parrainer vos confrères et gagner des récompenses."
    />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {steps.map((step, i) => (
        <div class="reveal relative" style={`transition-delay: ${i * 150}ms`}>
          {/* Connector line */}
          {i < steps.length - 1 && (
            <div class="hidden md:block absolute top-12 left-[60%] w-[80%] h-px bg-gradient-to-r from-pat-plum/30 to-transparent"></div>
          )}
          <div class="bg-white rounded-2xl border border-gray-100 p-8 card-hover relative">
            <div class="flex items-center gap-4 mb-6">
              <span class="text-5xl font-display font-extrabold gradient-text">{step.num}</span>
            </div>
            <h3 class="font-display text-xl font-bold text-dark mb-3">{step.title}</h3>
            <p class="text-gray-500 leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- Reward highlight -->
  <Section bg="gray">
    <div class="max-w-4xl mx-auto">
      <div class="reveal bg-white rounded-3xl border border-gray-100 overflow-hidden shadow-lg">
        <div class="grid grid-cols-1 md:grid-cols-2">
          <div class="gradient-bg p-8 md:p-12 flex flex-col justify-center">
            <span class="text-pat-plum text-sm font-semibold tracking-wider uppercase mb-3">Votre récompense</span>
            <h3 class="font-display text-4xl md:text-5xl font-extrabold text-white mb-2">215 €</h3>
            <p class="text-gray-300 text-lg">en parts de SCPI</p>
            <div class="mt-6 pt-6 border-t border-white/10">
              <p class="text-gray-400 text-sm">ou</p>
              <h3 class="font-display text-3xl font-extrabold text-white mt-1">100 €</h3>
              <p class="text-gray-300">par virement bancaire</p>
            </div>
          </div>
          <div class="p-8 md:p-12 flex flex-col justify-center">
            <h3 class="font-display text-2xl font-bold text-dark mb-4">Pourquoi la SCPI ?</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-pat-plum mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-600">Un placement immobilier à forte performance</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-pat-plum mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-600">Des revenus complémentaires réguliers</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-pat-plum mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-600">215 € de valeur immédiate pour vous</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Formulaire Tally -->
  <Section id="formulaire-parrainage">
    <SectionTitle
      title="Parrainez un"
      highlight="confrère"
      subtitle="Remplissez le formulaire ci-dessous pour parrainer un confrère et recevoir votre récompense."
    />
    <div class="max-w-2xl mx-auto">
      <div class="bg-white rounded-2xl border border-gray-100 p-8 shadow-sm">
        <iframe
          data-tally-src="https://tally.so/embed/3yDyDB?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
          loading="lazy"
          width="100%"
          height="300"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          title="Formulaire de parrainage"
          class="rounded-xl"
          style="min-height: 300px;"
        ></iframe>
      </div>
    </div>

    <p class="text-center text-gray-400 text-sm mt-6">
      *215 € en parts de SCPI ou 100 € par virement bancaire, après ouverture d'une Assurance Vie ou d'un PER par le filleul.
    </p>
  </Section>

  <!-- CTA -->
  <Section bg="dark">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-6">
        Des questions sur le <span class="text-primary-300">parrainage</span> ?
      </h2>
      <p class="text-gray-300 text-lg mb-8">
        Notre équipe est disponible pour répondre à toutes vos questions.
      </p>
      <Button href="/contact" variant="primary" size="lg">
        Contactez-nous
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </Button>
    </div>
  </Section>
</Layout>

<script>
  // Load Tally embed script
  const d = document;
  const w = "https://tally.so/widgets/embed.js";
  const v = function() {
    if (typeof (window as any).Tally !== 'undefined') {
      (window as any).Tally.loadEmbeds();
    } else {
      d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach((e: any) => {
        e.src = e.dataset.tallySrc;
      });
    }
  };
  if (typeof (window as any).Tally !== 'undefined') {
    v();
  } else if (!d.querySelector(`script[src="${w}"]`)) {
    const s = d.createElement("script");
    s.src = w;
    s.onload = v;
    s.onerror = v;
    d.body.appendChild(s);
  }
</script>
