---
interface Props {
  title: string;
  excerpt: string;
  date: Date;
  slug: string;
  image?: string;
  tag?: string;
}

const { title, excerpt, date, slug, image, tag } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(date);
---

<a href={`/patriactu/${slug}`} class="reveal group block">
  <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden card-hover">
    <!-- Image -->
    <div class="aspect-[16/9] bg-gray-100 relative overflow-hidden">
      {image ? (
        <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
      ) : (
        <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
          <svg class="w-12 h-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
        </div>
      )}
      {tag && (
        <span class="absolute top-3 left-3 px-3 py-1 bg-pat-plum text-white text-xs font-semibold rounded-full">
          {tag}
        </span>
      )}
    </div>

    <!-- Content -->
    <div class="p-6">
      <p class="text-xs text-gray-400 mb-2">{formattedDate}</p>
      <h3 class="font-display text-lg font-bold text-dark mb-2 group-hover:text-pat-plum transition-colors line-clamp-2">
        {title}
      </h3>
      <p class="text-gray-500 text-sm leading-relaxed line-clamp-3">{excerpt}</p>
      <span class="inline-flex items-center gap-1 text-pat-plum text-sm font-semibold mt-4 group-hover:gap-2 transition-all">
        Lire l'article
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </span>
    </div>
  </div>
</a>
