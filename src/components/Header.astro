---
interface Props {
  variant?: 'light' | 'dark';
}

const { variant = 'dark' } = Astro.props;

const navLinks = [
  { label: 'Nos Solutions', href: '/gestion-patrimoine' },
  { label: 'Partenaires', href: '/partenaires' },
  { label: 'Parrainage', href: '/parrainage' },
  { label: 'PatriActu', href: '/patriactu' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
const isLight = variant === 'light';
---

<header
  id="main-header"
  class:list={[
    'fixed top-0 left-0 right-0 z-50 transition-all duration-300',
    { 'header-light': isLight },
  ]}
>
  <div
    class:list={[
      'transition-all duration-300',
      isLight ? 'bg-transparent' : 'gradient-bg backdrop-blur-md bg-opacity-95',
    ]}
    id="header-bg"
  >
    <div class="container-custom">
      <div class="flex items-center justify-between h-16 md:h-20">
        <!-- Logo -->
        <a href="/" class="flex items-center group">
          {isLight ? (
            <img src="/images/logo-patrimed.svg" alt="Patrimed" class="h-8 md:h-10 w-auto header-logo-dark" />
            <img src="/images/logo-patrimed-white.svg" alt="Patrimed" class="h-8 md:h-10 w-auto header-logo-white hidden" />
          ) : (
            <img src="/images/logo-patrimed-white.svg" alt="Patrimed" class="h-8 md:h-10 w-auto" />
          )}
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-1">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'nav-link px-3 xl:px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200',
                currentPath === link.href || currentPath === link.href + '/'
                  ? isLight ? 'text-dark bg-gray-100' : 'text-white bg-white/15'
                  : isLight ? 'text-gray-600 hover:text-dark hover:bg-gray-50' : 'text-gray-300 hover:text-white hover:bg-white/10',
              ]}
            >
              {link.label}
            </a>
          ))}
        </nav>

        <!-- CTA + Mobile toggle -->
        <div class="flex items-center gap-3">
          <a
            href="/rdv"
            class="hidden sm:inline-flex items-center gap-2 px-5 py-2.5 bg-pat-plum text-white text-sm font-semibold rounded-xl transition-all duration-300 hover:bg-pat-burgundy hover:shadow-lg hover:shadow-pat-plum/30"
          >
            RDV VISIO GRATUIT
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </a>

          <!-- Mobile hamburger -->
          <button
            id="mobile-menu-btn"
            class:list={[
              'lg:hidden p-2 rounded-lg transition-colors',
              isLight ? 'text-dark hover:bg-gray-100 mobile-btn-light' : 'text-white hover:bg-white/10',
            ]}
            aria-label="Menu"
          >
            <svg id="hamburger-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden">
    <div class="gradient-bg border-t border-white/10 px-4 pb-6 pt-2">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'block px-4 py-3 text-sm font-medium rounded-lg transition-colors',
            currentPath === link.href || currentPath === link.href + '/'
              ? 'text-white bg-white/15'
              : 'text-gray-300 hover:text-white hover:bg-white/10',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/rdv"
        class="mt-4 flex items-center justify-center gap-2 px-5 py-3 bg-pat-plum text-white text-sm font-semibold rounded-xl transition-all duration-300 hover:bg-pat-burgundy"
      >
        RDV VISIO GRATUIT
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
      </a>
    </div>
  </div>
</header>

<!-- Spacer -->
<div class="h-16 md:h-20"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    hamburger?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  const header = document.getElementById('main-header');
  const headerBg = document.getElementById('header-bg');
  const isLightMode = header?.classList.contains('header-light');

  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY > 20;
    if (isLightMode) {
      if (scrolled) {
        header?.classList.add('header-scrolled');
        headerBg?.classList.remove('bg-transparent');
        headerBg?.classList.add('gradient-bg', 'backdrop-blur-md');
        header?.classList.add('shadow-xl');
        document.querySelectorAll('.header-logo-dark').forEach(el => el.classList.add('hidden'));
        document.querySelectorAll('.header-logo-white').forEach(el => el.classList.remove('hidden'));
        document.querySelectorAll('.nav-link').forEach(el => {
          el.classList.remove('text-gray-600', 'hover:text-dark', 'hover:bg-gray-50', 'text-dark', 'bg-gray-100');
          el.classList.add('text-gray-300', 'hover:text-white', 'hover:bg-white/10');
        });
        document.querySelectorAll('.mobile-btn-light').forEach(el => {
          el.classList.remove('text-dark', 'hover:bg-gray-100');
          el.classList.add('text-white', 'hover:bg-white/10');
        });
      } else {
        header?.classList.remove('header-scrolled');
        headerBg?.classList.add('bg-transparent');
        headerBg?.classList.remove('gradient-bg', 'backdrop-blur-md');
        header?.classList.remove('shadow-xl');
        document.querySelectorAll('.header-logo-dark').forEach(el => el.classList.remove('hidden'));
        document.querySelectorAll('.header-logo-white').forEach(el => el.classList.add('hidden'));
        document.querySelectorAll('.nav-link').forEach(el => {
          el.classList.add('text-gray-600', 'hover:text-dark', 'hover:bg-gray-50');
          el.classList.remove('text-gray-300', 'hover:text-white', 'hover:bg-white/10');
        });
        document.querySelectorAll('.mobile-btn-light').forEach(el => {
          el.classList.add('text-dark', 'hover:bg-gray-100');
          el.classList.remove('text-white', 'hover:bg-white/10');
        });
      }
    } else {
      if (scrolled) {
        header?.classList.add('shadow-xl');
      } else {
        header?.classList.remove('shadow-xl');
      }
    }
  });
</script>
