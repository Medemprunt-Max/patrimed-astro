---
interface Props {
  value: string;
  suffix?: string;
  label: string;
}

const { value, suffix = '', label } = Astro.props;
---

<div class="text-center">
  <div class="flex items-baseline justify-center gap-1">
    <span class="stat-value text-4xl md:text-5xl font-display font-extrabold text-white" data-value={value}>
      {value}
    </span>
    {suffix && (
      <span class="text-2xl md:text-3xl font-display font-bold text-pat-plum">{suffix}</span>
    )}
  </div>
  <p class="text-gray-400 text-sm mt-2">{label}</p>
</div>
