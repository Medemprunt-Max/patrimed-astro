---
interface Props {
  number: string;
  title: string;
  description: string;
  features: string[];
  icon: string;
  href?: string;
  accent?: boolean;
}

const { number, title, description, features, icon, href = '/rdv', accent = false } = Astro.props;
---

<div class:list={[
  'reveal rounded-2xl p-8 card-hover relative overflow-hidden group',
  accent
    ? 'bg-gradient-to-br from-pat-plum to-pat-burgundy text-white'
    : 'bg-white border border-gray-100',
]}>
  <div class="flex items-start justify-between mb-4">
    <span class:list={[
      'text-4xl font-display font-extrabold',
      accent ? 'text-white/30' : 'gradient-text',
    ]}>{number}.</span>
    <div class:list={[
      'w-12 h-12 rounded-xl flex items-center justify-center',
      accent ? 'bg-white/15' : 'bg-pat-plum/10',
    ]}>
      <svg class:list={['w-6 h-6', accent ? 'text-white' : 'text-pat-plum']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
      </svg>
    </div>
  </div>

  <h3 class:list={[
    'font-display text-xl font-bold mb-3',
    accent ? 'text-white' : 'text-dark',
  ]}>{title}</h3>

  <p class:list={[
    'text-sm leading-relaxed mb-4',
    accent ? 'text-white/80' : 'text-gray-500',
  ]}>{description}</p>

  <ul class="space-y-2 mb-6">
    {features.map((f) => (
      <li class="flex items-start gap-2">
        <svg class:list={['w-4 h-4 mt-0.5 flex-shrink-0', accent ? 'text-white/70' : 'text-pat-plum']} fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        <span class:list={['text-sm', accent ? 'text-white/80' : 'text-gray-500']}>{f}</span>
      </li>
    ))}
  </ul>

  <a
    href={href}
    class:list={[
      'inline-flex items-center gap-2 text-sm font-semibold transition-all duration-200',
      accent ? 'text-white hover:gap-3' : 'text-pat-plum hover:gap-3',
    ]}
  >
    En savoir plus
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
  </a>
</div>
