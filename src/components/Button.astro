---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'white';
  class?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { href, variant = 'primary', class: className = '', size = 'md' } = Astro.props;

const sizeClasses = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
};

const variantClasses = {
  primary: 'bg-pat-plum text-white hover:bg-pat-burgundy hover:shadow-lg hover:shadow-pat-plum/25',
  secondary: 'border-2 border-pat-plum text-pat-plum hover:bg-pat-plum hover:text-white',
  white: 'bg-white text-dark hover:shadow-lg hover:shadow-white/25',
};
---

{href ? (
  <a
    href={href}
    class:list={[
      'inline-flex items-center gap-2 font-semibold rounded-xl transition-all duration-300 active:scale-[0.98]',
      variantClasses[variant],
      sizeClasses[size],
      className,
    ]}
  >
    <slot />
  </a>
) : (
  <button
    class:list={[
      'inline-flex items-center gap-2 font-semibold rounded-xl transition-all duration-300 active:scale-[0.98]',
      variantClasses[variant],
      sizeClasses[size],
      className,
    ]}
  >
    <slot />
  </button>
)}
