---
interface Props {
  title: string;
  highlight?: string;
  subtitle?: string;
}

const { title, highlight, subtitle } = Astro.props;
---

<section class="relative gradient-bg overflow-hidden">
  <!-- Decorative elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-pat-plum/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-24 -left-24 w-72 h-72 bg-accent/10 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-white/[0.02] rounded-full"></div>
  </div>

  <div class="container-custom relative py-16 md:py-24 text-center">
    <h1 class="font-display text-3xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">
      {title}
      {highlight && <span class="gradient-text"> {highlight}</span>}
    </h1>
    {subtitle && (
      <p class="mt-4 md:mt-6 text-gray-300 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
        {subtitle}
      </p>
    )}
  </div>
</section>
